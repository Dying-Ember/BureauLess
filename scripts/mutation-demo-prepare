#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WORKSPACE="${1:-.bureauless/mutation-demo}"

if ! command -v uv >/dev/null 2>&1; then
  echo "uv is required. Install uv, then run 'uv sync --dev' from $ROOT_DIR." >&2
  exit 1
fi

unset VIRTUAL_ENV
cd "$ROOT_DIR"
uv run python -m bureauless mission mutation-demo "$WORKSPACE"

echo
echo "Start the API and web workbench in separate terminals:"
echo "  npm run api:dev"
echo "  npm run web:dev"
